# =============================================================================
# DevOps Monitor — .gitignore
# =============================================================================

# --- Environnement Python ---
.venv/
venv/
env/
ENV/
.env
*.env
!.env.example

# --- Cache Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# --- Tests & Coverage ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
nosetests.xml
pytest.ini

# --- Build / Distribution ---
dist/
build/
*.egg-info/
*.egg
wheels/
sdist/

# --- IDEs ---
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# --- OS ---
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini

# --- Docker ---
*.dockerignore

# --- Logs ---
*.log
logs/

# --- Secrets (sécurité) ---
*.pem
*.key
*.p12
secrets/
credentials/
